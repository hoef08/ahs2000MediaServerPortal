# Server
PORT=3000
API_KEY=

# Spotify (PKCE – kein Client Secret)
SPOTIFY_CLIENT_ID=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_MARKET=DE
# Im Spotify Developer Portal eintragen: http://127.0.0.1:3000/auth/spotify/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback

# Tidal (PKCE)
TIDAL_CLIENT_ID=
TIDAL_REFRESH_TOKEN=
TIDAL_COUNTRY_CODE=DE
# Im Tidal Developer Portal eintragen: http://127.0.0.1:3000/auth/tidal/callback
# Falls das Portal HTTPS verlangt: https://localhost/api/auth/tidal/callback
TIDAL_REDIRECT_URI=http://127.0.0.1:3000/auth/tidal/callback

